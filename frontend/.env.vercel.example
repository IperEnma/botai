# Variables en Vercel → Project → Settings → Environment Variables
# (Production). El script scripts/vercel-build.sh las escribe en .env al compilar.

# Backend Render (incluir /api al final)
API_BASE_URL=https://botai-backend.onrender.com/api

# Mismo OAuth "Web application" que en Render (GOOGLE_CLIENT_ID / GOOGLE_CLIENT_ID_WEB)
GOOGLE_CLIENT_ID_WEB=xxxx.apps.googleusercontent.com

# Opcional
# AGENDA_API_BASE_URL=
# AGENDA_PLATFORM_ADMIN=false
