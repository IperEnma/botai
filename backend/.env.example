# Flyway Agenda: tras editar migraciones ya aplicadas, true actualiza checksums al arrancar (o ejecutar: mvn flyway:repair).
# En producción conviene false y migraciones inmutables.
FLYWAY_REPAIR_ON_MIGRATE=true

# Database
DB_HOST=localhost
DB_PORT=5444
DB_NAME=chatbot
DB_USER=chatbot
DB_PASSWORD=chatbot

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# Ollama (chat LLM)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings RAG: djl (local, default) | api (OpenAI-compatible: OpenRouter, Ollama /v1, OpenAI)
BOT_EMBEDDING_PROVIDER=djl
# Render / OpenRouter:
# BOT_EMBEDDING_PROVIDER=api
# OPENROUTER_API_KEY=sk-or-v1-...
# BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
# BOT_EMBEDDING_API_BASE_URL=https://openrouter.ai/api
# Ollama como API de embeddings (mismo host que chat, otro endpoint /v1):
# BOT_EMBEDDING_PROVIDER=api
# BOT_EMBEDDING_API_BASE_URL=http://localhost:11434
# BOT_EMBEDDING_API_MODEL=nomic-embed-text

# Google OAuth — validación JWT del panel (mismo id_token que manda Flutter en Authorization).
# En Web el aud del token es el cliente "Web application". Usá el mismo valor que GOOGLE_CLIENT_ID_WEB del frontend.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Opcional: si no querés duplicar el nombre, podés definir solo esto (mismo valor que en frontend/.env):
# GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
