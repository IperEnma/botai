# Copiar a backend/.env (no commitear).
# Valores de ejemplo — sustituir secretos y URLs por los tuyos.

FLYWAY_REPAIR_ON_MIGRATE=true

# --- Base de datos (local Docker: docker-compose) -----------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5444/chatbot
SPRING_DATASOURCE_USERNAME=chatbot
SPRING_DATASOURCE_PASSWORD=chatbot

# --- Chat + embeddings (local por defecto: Ollama + DJL, $0) ------------------
BOT_EMBEDDING_PROVIDER=djl
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Opcional: chat por OpenRouter sin pagar embeddings API -------------------
# Descomentar si querés probar el mismo stack que Render sin Ollama local:
# BOT_CHAT_PROVIDER=api
# BOT_API_BASE_URL=https://openrouter.ai/api
# OPENROUTER_API_KEY=sk-or-v1-...
# BOT_CHAT_API_MODEL=openrouter/free

# --- Opcional: todo por OpenRouter (embeddings de pago, chat free) ------------
# BOT_EMBEDDING_PROVIDER=api
# BOT_API_BASE_URL=https://openrouter.ai/api
# OPENROUTER_API_KEY=sk-or-v1-...
# BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
# BOT_CHAT_API_MODEL=openrouter/free
# Evitar: BOT_CHAT_API_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Agenda (local) -----------------------------------------------------------
AGENDA_PUBLIC_BASE_URL=http://localhost:8080
AGENDA_UPLOADS_BASE_URL=http://localhost:8080/uploads
AGENDA_SECURITY_ENABLED=false

# --- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# WhatsApp: credenciales por bot en el panel admin (columnas bot.whatsapp_*), no env vars.
# Render / Neon: ver backend/.env.render.example y deploy/RENDER.md
