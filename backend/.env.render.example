# =============================================================================
# Render → Web Service → Environment (copiar claves/valores al dashboard).
# Ver también render.yaml (Blueprint) y deploy/RENDER.md.
# =============================================================================

# --- Base de datos (Neon) -----------------------------------------------------
# Neon da: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# En Render: tres variables (host/BD en URL; usuario y contraseña aparte). Ver deploy/RENDER.md.
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=

FLYWAY_REPAIR_ON_MIGRATE=false
JAVA_OPTS=-Xmx384m

# --- OpenRouter (chat + embeddings RAG) -----------------------------------------
# BOT_EMBEDDING_PROVIDER=api activa el perfil en application.yml que usa Spring AI
# "openai" apuntando a la misma URL para chat y vectores:
#
#   BOT_API_BASE_URL      → spring.ai.openai.base-url   (proveedor HTTP)
#   OPENROUTER_API_KEY    → spring.ai.openai.api-key
#   BOT_EMBEDDING_API_MODEL → modelo de embeddings
#   BOT_CHAT_API_MODEL      → modelo de chat
#
BOT_EMBEDDING_PROVIDER=api
BOT_API_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
BOT_CHAT_API_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Agenda -------------------------------------------------------------------
# URL del frontend (Vercel): https://tu-proyecto.vercel.app — ver deploy/VERCEL.md
AGENDA_PUBLIC_BASE_URL=https://tu-proyecto.vercel.app
AGENDA_UPLOADS_BASE_URL=https://botai-backend.onrender.com/uploads
AGENDA_SECURITY_ENABLED=true

# --- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# WhatsApp: credenciales en el panel del bot (tabla bot), no env vars globales.
