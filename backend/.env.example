# Copiar a backend/.env (no commitear).

FLYWAY_REPAIR_ON_MIGRATE=true

# Base de datos — una URL (local Docker). Neon/Render: pegar connection string con prefijo jdbc:
# DATABASE_URL=jdbc:postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=jdbc:postgresql://chatbot:chatbot@localhost:5444/chatbot

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# Ollama (chat LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings RAG: djl (local) | api (OpenRouter en Render)
BOT_EMBEDDING_PROVIDER=djl

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
