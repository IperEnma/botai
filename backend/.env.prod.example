# Copiar a backend/.env.prod en el servidor (NO commitear).
# Oracle / VPS con más RAM: DJL + Ollama. Render: usar .env.render.example.

SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=

FLYWAY_REPAIR_ON_MIGRATE=false
JAVA_OPTS=-Xmx3g

# --- IA: sin cargos OpenRouter (chat free + embeddings en JVM) ----------------
BOT_EMBEDDING_PROVIDER=djl
BOT_CHAT_PROVIDER=api
BOT_API_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_CHAT_API_MODEL=openrouter/free

# Si preferís embeddings por API (de pago) en un VPS con poca RAM para DJL:
# BOT_EMBEDDING_PROVIDER=api
# BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
# BOT_CHAT_API_MODEL=openrouter/free

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

CADDY_DOMAIN=api.tudominio.com
AGENDA_PUBLIC_BASE_URL=https://app.tudominio.com
AGENDA_UPLOADS_BASE_URL=https://api.tudominio.com/uploads
AGENDA_SECURITY_ENABLED=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
