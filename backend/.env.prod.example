# Copiar a backend/.env.prod en el servidor (NO commitear).
# cp backend/.env.prod.example backend/.env.prod

# --- Base de datos Neon (pgvector) — desde panel Neon → Connection details ---
DB_HOST=ep-xxxx.region.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=PEGAR_PASSWORD_DE_NEON
# Neon exige SSL; en Postgres local dejar vacío o omitir
DB_JDBC_PARAMS=?sslmode=require

# --- Prod ---
SPRING_SQL_INIT_MODE=never
FLYWAY_REPAIR_ON_MIGRATE=false
SERVER_PORT=8080

# Embeddings: en VM pequeña (12 GB) conviene api + OpenRouter. En VM con margen: djl
BOT_EMBEDDING_PROVIDER=api
OPENROUTER_API_KEY=
BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
BOT_EMBEDDING_API_BASE_URL=https://openrouter.ai/api

# Caddy (dominio con HTTPS)
CADDY_DOMAIN=api.tudominio.com

# Agenda
AGENDA_PUBLIC_BASE_URL=https://app.tudominio.com
AGENDA_UPLOADS_BASE_URL=https://api.tudominio.com/uploads
AGENDA_SECURITY_ENABLED=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WhatsApp
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Chat LLM (opcional: Ollama en la VM o OpenRouter cuando esté cableado)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2
