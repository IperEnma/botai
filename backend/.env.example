# Flyway Agenda: tras editar migraciones ya aplicadas, true actualiza checksums al arrancar (o ejecutar: mvn flyway:repair).
# En producción conviene false y migraciones inmutables.
FLYWAY_REPAIR_ON_MIGRATE=true

# Database
DB_HOST=localhost
DB_PORT=5444
DB_NAME=chatbot
DB_USER=chatbot
DB_PASSWORD=chatbot

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# Ollama (AI)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google OAuth — validación JWT del panel (mismo id_token que manda Flutter en Authorization).
# En Web el aud del token es el cliente "Web application". Usá el mismo valor que GOOGLE_CLIENT_ID_WEB del frontend.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Opcional: si no querés duplicar el nombre, podés definir solo esto (mismo valor que en frontend/.env):
# GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
