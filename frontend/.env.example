# Host del backend Konecta (sin path). Mismo valor que PUBLIC_BACKEND_URL del backend.
# Los context paths se arman en AppConfig:
#   Chatbot API  → {KONECTA_BASE_URL}/api
#   Agenda API   → {KONECTA_BASE_URL}/api/agenda
#   Imágenes     → {KONECTA_BASE_URL}/uploads/…
KONECTA_BASE_URL=http://localhost:8080

# Legacy (opcional): si omitís KONECTA_BASE_URL, se deduce quitando /api de API_BASE_URL.
# API_BASE_URL=http://localhost:8080/api

# Google OAuth (Web: tipo "Web application" en Google Cloud Console)
GOOGLE_CLIENT_ID_WEB=your_client_id.apps.googleusercontent.com
# El backend debe validar el mismo aud: GOOGLE_CLIENT_ID o (si está vacío) GOOGLE_CLIENT_ID_WEB en backend/.env
GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com

# AGENDA module
# Override opcional de la base Agenda (default: {KONECTA_BASE_URL}/api/agenda).
AGENDA_API_BASE_URL=
# Si true, muestra el tile "Plataforma" en el landing /agenda (admin del catálogo global).
AGENDA_PLATFORM_ADMIN=false
# Solo dev: tenant precargado para entrar a /agenda/tenants/<id> sin login.
AGENDA_DEFAULT_TENANT_ID=
# Solo dev: userId que se manda como X-User-Id mientras no haya auth real.
AGENDA_DEFAULT_USER_ID=

# Google Maps (opcional): miniatura estática en perfil público + enlace "Ver en el mapa"
# Habilitar "Maps Static API" en Google Cloud Console.
GOOGLE_MAPS_API_KEY=

# URL base del frontend público (compartir perfil en apps móviles sin web).
# Ej: https://tudominio.com
PUBLIC_APP_BASE_URL=
