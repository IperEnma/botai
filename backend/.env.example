# Copiar a backend/.env (no commitear).

FLYWAY_REPAIR_ON_MIGRATE=true

# Base de datos — local Docker (compose). En prod/Render: SPRING_DATASOURCE_* (ver .env.render.example).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5444/chatbot
SPRING_DATASOURCE_USERNAME=chatbot
SPRING_DATASOURCE_PASSWORD=chatbot

# WhatsApp: credenciales por bot en el panel admin (columnas bot.whatsapp_*), no env vars.

# Ollama (chat LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings RAG: djl (local) | api (OpenRouter en Render)
BOT_EMBEDDING_PROVIDER=djl

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
