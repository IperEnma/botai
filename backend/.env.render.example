# =============================================================================
# Render → Web Service → Environment (copiar al dashboard).
# Ver render.yaml y deploy/RENDER.md
# =============================================================================

# --- Base de datos (Neon) -----------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=

FLYWAY_REPAIR_ON_MIGRATE=false
JAVA_OPTS=-Xmx384m

# --- IA ($0 OpenRouter: chat + embeddings en API, sin DJL en el servidor) -----
BOT_EMBEDDING_PROVIDER=api
BOT_API_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_EMBEDDING_API_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
BOT_EMBEDDING_API_DIMENSIONS=384
BOT_CHAT_API_MODEL=openrouter/free

# --- Agenda -------------------------------------------------------------------
AGENDA_PUBLIC_BASE_URL=https://tu-proyecto.vercel.app
AGENDA_UPLOADS_BASE_URL=https://botai-backend.onrender.com/uploads
AGENDA_SECURITY_ENABLED=true

# --- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# WhatsApp: credenciales en el panel del bot (tabla bot), no env vars globales.

# --- No usar (generan cargo) --------------------------------------------------
# BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
# BOT_CHAT_API_MODEL=meta-llama/llama-3.3-70b-instruct
# BOT_EMBEDDING_PROVIDER=djl
