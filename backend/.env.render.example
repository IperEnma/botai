# Variables para Render (Dashboard → Environment). NO commitear secretos.
# Embeddings: API (OpenRouter). Chat: Ollama en URL accesible desde internet.

SPRING_SQL_INIT_MODE=never
FLYWAY_REPAIR_ON_MIGRATE=false

# Neon → Connection details (Direct, SSL)
DB_HOST=ep-xxxx.region.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=
DB_JDBC_PARAMS=?sslmode=require

BOT_EMBEDDING_PROVIDER=api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small
BOT_EMBEDDING_API_BASE_URL=https://openrouter.ai/api

# Tras el primer deploy: https://botai-backend.onrender.com
AGENDA_PUBLIC_BASE_URL=https://tu-frontend.com
AGENDA_UPLOADS_BASE_URL=https://botai-backend.onrender.com/uploads
AGENDA_SECURITY_ENABLED=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Chat (Ollama fuera de Render: túnel, otra VM, etc.). localhost NO funciona en Render.
OLLAMA_BASE_URL=https://tu-ollama-publica:11434
OLLAMA_MODEL=llama3.2

JAVA_OPTS=-Xmx384m
