# Copiar a backend/.env.prod en el servidor (NO commitear).

SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=

FLYWAY_REPAIR_ON_MIGRATE=false
JAVA_OPTS=-Xmx3g

PUBLIC_BACKEND_URL=https://api.tudominio.com
PUBLIC_FRONTEND_URL=https://app.tudominio.com

# OpenRouter $0 (sin DJL en servidor)
BOT_EMBEDDING_PROVIDER=api
BOT_API_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_EMBEDDING_API_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
BOT_EMBEDDING_API_DIMENSIONS=384
BOT_CHAT_API_MODEL=openrouter/free

AGENDA_SECURITY_ENABLED=true

# OTP / sesión pública agenda (obligatorio en prod)
AGENDA_PHONE_VERIFICATION_HASH_PEPPER=
AGENDA_PHONE_VERIFICATION_PROD_GUARD=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BOT_WHATSAPP_VERIFY_SECRET=
BOT_WHATSAPP_ENCRYPTION_SECRET=
