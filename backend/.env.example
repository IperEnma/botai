# Copiar a backend/.env (no commitear).

FLYWAY_REPAIR_ON_MIGRATE=true

# --- Base de datos (local Docker) ---------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5444/chatbot
SPRING_DATASOURCE_USERNAME=chatbot
SPRING_DATASOURCE_PASSWORD=chatbot

# --- Local: Ollama (chat) + DJL (embeddings en JVM, $0) ------------------------
BOT_EMBEDDING_PROVIDER=djl
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Opcional: mismo stack que Render (OpenRouter free, sin DJL) --------------
# BOT_EMBEDDING_PROVIDER=api
# BOT_API_BASE_URL=https://openrouter.ai/api
# OPENROUTER_API_KEY=sk-or-v1-...
# BOT_EMBEDDING_API_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# BOT_EMBEDDING_API_DIMENSIONS=384
# BOT_CHAT_API_MODEL=openrouter/free

# --- Agenda (local) -----------------------------------------------------------
AGENDA_PUBLIC_BASE_URL=http://localhost:8080
AGENDA_UPLOADS_BASE_URL=http://localhost:8080/uploads
AGENDA_SECURITY_ENABLED=false

# --- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Secreto HMAC verify token + cifrado AES access tokens (nunca en BD en claro).
BOT_WHATSAPP_VERIFY_SECRET=dev-insecure-change-me
BOT_WHATSAPP_ENCRYPTION_SECRET=dev-insecure-change-me
BOT_PUBLIC_BASE_URL=http://localhost:8080
# Opcional legacy (single-tenant antiguo):
# BOT_WHATSAPP_VERIFY_TOKEN=

# Phone/access token: por bot en el panel admin.
