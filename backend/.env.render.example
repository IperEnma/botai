# =============================================================================
# Render → Web Service → Environment (copiar claves/valores al dashboard).
# Ver también render.yaml (Blueprint) y deploy/RENDER.md.
# =============================================================================

# --- Base de datos (Neon) -----------------------------------------------------
# Neon da: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# En Render definí TRES variables (no pegues la URL completa en una sola):
#   - Host + BD + query → SPRING_DATASOURCE_URL (jdbc:, puerto 5432, sin channel_binding)
#   - Usuario y contraseña → USERNAME / PASSWORD por separado
# En Neon: activar extensión pgvector (Settings o SQL Editor).
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=

# Tablas agenda_* + bot: Hibernate (ddl-auto=update) + Flyway V1–V4 al arrancar.
FLYWAY_REPAIR_ON_MIGRATE=false

# Render inyecta PORT; no hace falta definirlo salvo prueba local del JAR.
# SERVER_PORT=8080

JAVA_OPTS=-Xmx384m

# --- Embeddings RAG (obligatorio en Render: sin DJL) ----------------------------
BOT_EMBEDDING_PROVIDER=api
OPENROUTER_API_KEY=sk-or-v1-...
BOT_EMBEDDING_API_BASE_URL=https://openrouter.ai/api
# openai/text-embedding-3-small → 1536 dimensiones. La entidad JPA usa vector(384)
# hoy: o cambiás el modelo a uno de 384 dims, o migrás la columna en Neon antes del
# primer embed (ver deploy/RENDER.md § dimensiones).
BOT_EMBEDDING_API_MODEL=openai/text-embedding-3-small

# --- Agenda -------------------------------------------------------------------
AGENDA_PUBLIC_BASE_URL=https://tu-frontend.onrender.com
AGENDA_UPLOADS_BASE_URL=https://botai-backend.onrender.com/uploads
AGENDA_SECURITY_ENABLED=true

# --- Google OAuth (login tenant / admin agenda) --------------------------------
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# --- Chat LLM vía Ollama (opcional; sin URL pública el chat del bot no responde) -
# WhatsApp: configurar en el panel del bot (tabla bot), no hay env vars globales.
OLLAMA_BASE_URL=https://tu-ollama-publica:11434
OLLAMA_MODEL=llama3.2
